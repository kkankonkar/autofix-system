# Fixium Local Testing Configuration
# Copy this file to secrets.env and fill in your values
# secrets.env is gitignored and will not be committed

# GitHub Authentication
export GITHUB_TOKEN="your_github_token_here"
export MY_GITHUB_TOKEN="your_github_token_here"  # Same as GITHUB_TOKEN

# Repository Information
export GITHUB_OWNER="your-github-username"
export GITHUB_REPO="your-repo-name"
export GITHUB_REPOSITORY="your-github-username/your-repo-name"

# Bob Shell API Key
export BOBSHELL_API_KEY="your_bobshell_api_key"

# Authorized Users (comma-separated)
export FIXIUM_AUTHORIZED_USERS="user1,user2,user3"

# Test PR Configuration
export PR_NUMBER="1"
export COMMENT_BODY="Fixium:review"
export COMMENT_USER="your-github-username"

# Optional: GitHub API URL (defaults to https://api.github.com)
# export GITHUB_API_URL="https://api.github.com"