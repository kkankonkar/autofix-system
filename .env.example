# AutoFix System - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ============================================
# AI Agent Configuration
# ============================================

# Bob CLI (Primary AI Agent)
BOBSHELL_API_KEY=your-bobshell-api-key-here
AI_AGENT_PRIMARY=bob_cli
BOB_CLI_COMMAND=bob

# OpenAI (Fallback AI Agent)
AI_AGENT_FALLBACK=openai
OPENAI_API_KEY=your-openai-api-key-here

# ============================================
# GitHub Configuration
# ============================================

GITHUB_TOKEN=ghp_your_github_personal_access_token_here

# ============================================
# MySQL Database Configuration
# ============================================

# Database Connection
DATABASE_URL=mysql+pymysql://autofix:autofix123@mysql:3306/autofix_analytics
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=autofix
MYSQL_PASSWORD=autofix123
MYSQL_DATABASE=autofix_analytics
MYSQL_ROOT_PASSWORD=rootpassword

# For AWS RDS (Production)
# DATABASE_URL=mysql+pymysql://username:password@your-rds-endpoint.region.rds.amazonaws.com:3306/autofix_analytics
# MYSQL_HOST=your-rds-endpoint.region.rds.amazonaws.com
# MYSQL_PORT=3306
# MYSQL_USER=admin
# MYSQL_PASSWORD=your-secure-password
# MYSQL_DATABASE=autofix_analytics

# ============================================
# Analytics API Configuration
# ============================================

# API Key for analytics endpoints (Bearer token authentication)
ANALYTICS_API_KEY=your-secret-api-key-here

# ============================================
# Application Configuration
# ============================================

# Environment (development, staging, production)
ENVIRONMENT=development

# Logging
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1

# ============================================
# Optional: AWS Configuration (for RDS)
# ============================================

# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# ============================================
# Security Notes
# ============================================

# 1. Never commit .env file to version control
# 2. Use strong passwords for production databases
# 3. Rotate API keys regularly
# 4. Use AWS Secrets Manager or similar for production
# 5. Restrict database access to application IP only
# 6. Enable SSL/TLS for database connections in production

# Made with Bob