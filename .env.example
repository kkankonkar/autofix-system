# CodeMedic AutoFix System - Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control!

# ============================================================================
# REQUIRED: GitHub Configuration
# ============================================================================
# GitHub Personal Access Token with repo permissions
# Get it from: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_github_token_here

# ============================================================================
# REQUIRED: Bob CLI Configuration (Primary AI Agent)
# ============================================================================
# Bob Shell API Key from IBM
# Get it from: https://bob.ibm.com/
BOBSHELL_API_KEY=your_bobshell_api_key_here

# ============================================================================
# OPTIONAL: OpenAI Configuration (Fallback AI Agent)
# ============================================================================
# OpenAI API Key (used as fallback when Bob CLI is unavailable)
# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here

# ============================================================================
# OPTIONAL: AI Agent Configuration
# ============================================================================
# Primary AI agent to use: bob_cli or openai
AI_AGENT_PRIMARY=bob_cli

# Fallback AI agent when primary fails
AI_AGENT_FALLBACK=openai

# Bob CLI command (default: bob)
BOB_CLI_COMMAND=bob

# ============================================================================
# OPTIONAL: Application Configuration
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL

# Maximum number of errors to process per log file (default: 3)
# Increase this to process more errors, decrease to process fewer
MAX_ERRORS_PER_LOG=3
LOG_LEVEL=INFO

# ============================================================================
# USAGE INSTRUCTIONS
# ============================================================================
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Edit .env and add your actual API keys
#
# 3. Run with Docker Compose:
#    docker-compose up -d
#
# 4. Or run with Docker:
#    docker run --env-file .env -p 8000:8000 codemedic/autofix-system
#
# 5. Or run with Podman Compose:
#    podman-compose up -d
#
# ============================================================================

