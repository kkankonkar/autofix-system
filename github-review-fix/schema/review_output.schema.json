{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/fixium/review-output-schema/v1",
  "title": "Fixium Code Review Output Schema",
  "description": "Canonical schema for code review output produced by Bob Shell and consumed by Fixium Python runner",
  "type": "object",
  "required": ["pr_number", "files_reviewed", "review_summary", "findings"],
  "properties": {
    "pr_number": {
      "type": "integer",
      "description": "Pull request number being reviewed",
      "minimum": 1
    },
    "files_reviewed": {
      "type": "array",
      "description": "List of files that were reviewed",
      "items": {
        "type": "string"
      },
      "minItems": 0
    },
    "review_summary": {
      "type": "object",
      "description": "Summary statistics of the review",
      "required": ["total_findings", "critical", "high", "medium", "low"],
      "properties": {
        "total_findings": {
          "type": "integer",
          "description": "Total number of findings across all severity levels",
          "minimum": 0
        },
        "critical": {
          "type": "integer",
          "description": "Number of critical severity findings",
          "minimum": 0
        },
        "high": {
          "type": "integer",
          "description": "Number of high severity findings",
          "minimum": 0
        },
        "medium": {
          "type": "integer",
          "description": "Number of medium severity findings",
          "minimum": 0
        },
        "low": {
          "type": "integer",
          "description": "Number of low severity findings",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "findings": {
      "type": "array",
      "description": "List of code review findings",
      "items": {
        "type": "object",
        "required": ["file", "line", "severity", "type", "title", "description"],
        "properties": {
          "file": {
            "type": "string",
            "description": "File path relative to repository root"
          },
          "line": {
            "type": "integer",
            "description": "Line number where the issue occurs",
            "minimum": 1
          },
          "column": {
            "type": "integer",
            "description": "Column number where the issue occurs (optional)",
            "minimum": 1
          },
          "severity": {
            "type": "string",
            "description": "Severity level of the finding",
            "enum": ["critical", "high", "medium", "low"]
          },
          "type": {
            "type": "string",
            "description": "Type/category of the finding",
            "enum": [
              "security",
              "bug",
              "maintainability",
              "performance",
              "style"
            ]
          },
          "title": {
            "type": "string",
            "description": "Short title summarizing the issue",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "description": "Detailed description of the issue",
            "minLength": 1
          },
          "details": {
            "type": "string",
            "description": "Additional context or explanation (optional)"
          },
          "bob_fixable": {
            "type": "boolean",
            "description": "Whether this finding can be safely targeted by the Fixium implement workflow",
            "default": false
          },
          "suggestion": {
            "type": "string",
            "description": "Suggested fix or remediation (optional)"
          },
          "code_snippet": {
            "type": "string",
            "description": "Code snippet showing the problematic code (optional)"
          }
        },
        "additionalProperties": false
      }
    },
    "recommendations": {
      "type": "array",
      "description": "High-level recommendations (optional)",
      "items": {
        "type": "object",
        "required": ["priority", "action"],
        "properties": {
          "priority": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "action": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "positive_aspects": {
      "type": "array",
      "description": "Positive aspects noted during review (optional)",
      "items": {
        "type": "string"
      }
    },
    "overall_assessment": {
      "type": "string",
      "description": "Overall assessment summary (optional)"
    },
    "reviewed_by": {
      "type": "string",
      "description": "Identifier of the reviewer (e.g., 'Bob Shell Code Review')"
    },
    "review_date": {
      "type": "string",
      "description": "ISO 8601 timestamp of when the review was completed",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}